  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "tsx src/index.ts",
    "traits": "tsx src/traits.ts",
    "traits:card": "tsx src/traits.ts --slug card_nft_2",
    "tensor": "tsx src/cli-tensor.ts",
    "binder": "vite --config vite.config.ts --logLevel info",
    "binder:force": "vite --config vite.config.ts --force",
    "binder:debug": "vite --config vite.config.ts --force --logLevel info",
    "binder:kill": "lsof -ti:5173 | xargs kill -9 2>/dev/null || true; echo 'port cleared'",
    "binder:build": "vite build --config vite.config.ts",
    "binder:preview": "vite build --config vite.config.ts && vite preview --config vite.config.ts --port 5174 --host 127.0.0.1",
    "css:build": "tailwindcss -c tailwind.config.cjs -i tailwind-src.css -o tailwind.css --minify"
  },
